# ── Backend (Render) ────────────────────────────────────────────────────────
# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# The Vercel frontend URL — used to restrict CORS to your domain only
# In development this defaults to http://localhost:5173
ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional: override the default port (3000)
# PORT=3000

# ── Frontend (Vercel) ────────────────────────────────────────────────────────
# Your Render backend URL — set this as a Vercel environment variable at build time
# In development this defaults to http://localhost:3000
VITE_API_URL=https://your-backend.onrender.com
