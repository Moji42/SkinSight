# ==========================
# Server / Flask Configuration
# ==========================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# CORS configuration (frontend origin)
FRONTEND_ORIGIN=http://localhost:3000

# ==========================
# OpenAI Configuration
# ==========================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_WITH_VISION=gpt-4o-mini-vision
# Optional: fallback text model
OPENAI_MODEL_TEXT=gpt-4o-mini

# ==========================
# Redis Configuration (for chat history)
# ==========================
# Local Redis for dev
REDIS_URL=redis://localhost:6379/0
# For production, use your managed Redis URL instead
# Example: redis://default:password@redis-host:6379/0

# ==========================
# Firebase Configuration (for image uploads)
# ==========================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# Keep \n literals in the key!
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-firebase-bucket.appspot.com

# Optional signed URL expiry (seconds)
SIGNED_URL_EXPIRATION=600
